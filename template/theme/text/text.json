{
  "theme": {
    "text": {
      "default": {
        "$type": "color",
        "$value": "{global.color.base.10}",
        "$extensions": { "mode": { "light": "{global.color.base.10}", "dark": "{global.color.base.0}" } }
      },
      "secondary": {
        "$type": "color",
        "$value": "{global.color.base.6}",
        "$extensions": { "mode": { "light": "{global.color.base.6}", "dark": "{global.color.base.3}" } }
      },
      "muted": {
        "$type": "color",
        "$value": "{global.color.base.4}",
        "$extensions": { "mode": { "light": "{global.color.base.4}", "dark": "{global.color.base.6}" } }
      }
    }
  }
}
