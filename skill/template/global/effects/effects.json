{
  "global": {
    "effects": {
      "shadow": {
        "1": { "$type": "shadow", "$value": { "color": "#0000001a", "offsetX": "0px", "offsetY": "1px",  "blur": "2px",  "spread": "0px" } },
        "2": { "$type": "shadow", "$value": { "color": "#00000026", "offsetX": "0px", "offsetY": "4px",  "blur": "8px",  "spread": "0px" } },
        "3": { "$type": "shadow", "$value": { "color": "#00000033", "offsetX": "0px", "offsetY": "12px", "blur": "24px", "spread": "0px" } }
      },
      "blur": {
        "1": { "$type": "dimension", "$value": "4px" },
        "2": { "$type": "dimension", "$value": "8px" },
        "3": { "$type": "dimension", "$value": "16px" }
      }
    }
  }
}
